# Server Settings
ENVIRONMENT=development
PROJECT_NAME="Payment Service"
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Database Settings
# For PostgreSQL: postgresql://user:password@localhost:5432/dbname
# For SQLite: sqlite:///./payment.db
DATABASE_URL=sqlite:///./payment.db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Security Settings
# Generate a secure secret key via `openssl rand -hex 32`
SECRET_KEY=supersecretkeyplaceholder
API_KEY=localdevapikeyplaceholder

# eSewa Intent API v2 Settings
ESEWA_INTENT_KEY=
ESEWA_INTENT_PRODUCT_CODE=
ESEWA_INTENT_BOOK_URL=https://checkout.esewa.com.np/api/client/intent/payment/book
ESEWA_INTENT_STATUS_URL=https://checkout.esewa.com.np/api/client/intent/payment/status
BACKEND_API_URL=http://localhost:8000
